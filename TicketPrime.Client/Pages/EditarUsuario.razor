@page "/usuarios/editar/{Cpf}"
@using System.ComponentModel.DataAnnotations
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Editar Usuário</PageTitle>

<section class="user-form-page">
    <div class="user-form-shell">
        <div class="user-form-header">
            <span class="user-form-eyebrow">Gestão de contas</span>
            <h1>Editar usuário</h1>
            <p>Atualize os dados do usuário cadastrado no sistema.</p>
        </div>

        <MudPaper Class="user-form-card" Elevation="0">
            @if (_loadingData)
            {
                <div class="form-loading">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled" Class="mb-4">
                        @_errorMessage
                    </MudAlert>
                }

                <EditForm Model="@_form" OnValidSubmit="@HandleSubmitAsync">
                    <DataAnnotationsValidator />

                    <div class="form-grid">
                        <MudTextField T="string"
                                      Label="Nome"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      For="@(() => _form.Nome)"
                                      @bind-Value="_form.Nome" />

                        <MudTextField T="string"
                                      Label="Email"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      InputType="InputType.Email"
                                      For="@(() => _form.Email)"
                                      @bind-Value="_form.Email" />

                        <MudTextField T="string"
                                      Label="Senha"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      InputType="InputType.Password"
                                      For="@(() => _form.Senha)"
                                      @bind-Value="_form.Senha" />

                        <MudTextField T="string"
                                      Label="CPF"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      Placeholder="000.000.000-00"
                                      For="@(() => _form.Cpf)"
                                      @bind-Value="_form.Cpf" />
                    </div>

                    <div class="form-actions">
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@_isSubmitting">
                            @(_isSubmitting ? "Salvando..." : "Salvar")
                        </MudButton>

                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   Disabled="@_isSubmitting"
                                   OnClick="@(() => Navigation.NavigateTo("/usuarios"))">
                            Cancelar
                        </MudButton>
                    </div>
                </EditForm>
            }
        </MudPaper>
    </div>
</section>

@code {
    [Parameter]
    public string Cpf { get; set; } = string.Empty;

    private UsuarioFormModel _form = new();
    private bool _isSubmitting;
    private bool _loadingData = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var usuario = await Http.GetFromJsonAsync<UsuarioData>($"api/usuarios/{Cpf}");
            if (usuario is not null)
            {
                _form.Nome = usuario.Nome;
                _form.Email = usuario.Email;
                _form.Senha = usuario.Senha;
                _form.Cpf = usuario.Cpf;
            }
            else
            {
                _errorMessage = "Usuário não encontrado.";
            }
        }
        catch
        {
            _errorMessage = "Erro ao carregar dados do usuário.";
        }
        finally
        {
            _loadingData = false;
        }
    }

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var payload = new
            {
                Nome = _form.Nome!.Trim(),
                Email = _form.Email!.Trim(),
                Senha = _form.Senha,
                Cpf = _form.Cpf!.Trim()
            };

            var response = await Http.PutAsJsonAsync($"api/usuarios/{Cpf}", payload);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Usuário atualizado com sucesso!", Severity.Success);
                Navigation.NavigateTo("/usuarios");
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                _errorMessage = string.IsNullOrWhiteSpace(body)
                    ? "Erro ao atualizar usuário."
                    : body.Trim('"');
            }
        }
        catch
        {
            _errorMessage = "Erro de conexão com o servidor.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private class UsuarioData
    {
        public string Nome { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Senha { get; set; } = string.Empty;
        public string Cpf { get; set; } = string.Empty;
    }

    private class UsuarioFormModel
    {
        [Required(ErrorMessage = "Nome é obrigatório.")]
        public string? Nome { get; set; }

        [Required(ErrorMessage = "Email é obrigatório.")]
        [EmailAddress(ErrorMessage = "Email inválido.")]
        public string? Email { get; set; }

        [Required(ErrorMessage = "Senha é obrigatória.")]
        [MinLength(6, ErrorMessage = "Senha deve ter pelo menos 6 caracteres.")]
        public string? Senha { get; set; }

        [Required(ErrorMessage = "CPF é obrigatório.")]
        public string? Cpf { get; set; }
    }
}
