@page "/entrar"
@layout PublicLayout
@inject MudBlazor.ISnackbar Snackbar

<PageTitle>Entrar — TicketPrime</PageTitle>

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <span class="login-icon">🎟</span>
            <h1>Bem-vindo!</h1>
            <p>Entre na sua conta TicketPrime</p>
        </div>

        <div class="login-form">
            <div class="login-field">
                <label for="email">E-mail</label>
                <input id="email" class="login-input" type="email" placeholder="maria@email.com" />
            </div>

            <div class="login-field">
                <label for="senha">Senha</label>
                <input id="senha" class="login-input" type="password" placeholder="Sua senha" />
            </div>
        </div>

        <button class="login-btn-submit" @onclick="HandleLogin">
            Entrar
        </button>

        <p class="login-footer-text">
            Não tem uma conta?
            <a href="/registrar" class="login-link">Criar conta</a>
        </p>
    </div>
</div>

@code {
    private void HandleLogin()
    {
        Snackbar.Add("Funcionalidade de login em breve! 🚀", MudBlazor.Severity.Info);
    }
}
