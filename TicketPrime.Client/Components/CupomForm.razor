@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using TicketPrime.Client.Services.Cupons
@inject ICupomService CupomService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>@PageTitleText</PageTitle>

<section class="coupon-form-page">
    <div class="coupon-form-shell">
        <div class="coupon-form-header">
            <span class="coupon-form-eyebrow">Operação de cupons</span>
            <h1>@HeaderTitle</h1>
            <p>@HeaderDescription</p>
        </div>

        <MudPaper Class="coupon-form-card" Elevation="0">
            @if (isLoading)
            {
                <div class="form-loading">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled" Class="mb-4">
                        @errorMessage
                    </MudAlert>
                }

                <EditForm Model="@form" OnValidSubmit="@HandleSubmitAsync" @key="form">
                    <DataAnnotationsValidator />

                    <div class="form-grid">
                        <MudTextField T="string"
                                      Label="Código"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      For="@(() => form.Codigo)"
                                      @bind-Value="form.Codigo" />

                        <MudNumericField T="decimal?"
                                         Label="Porcentagem de desconto"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="1"
                                         Max="100"
                                         Class="percent-field"
                                         Culture="ptBr"
                                         Format="N0"
                                         Adornment="Adornment.End"
                                         AdornmentText="%"
                                         FullWidth="true"
                                         For="@(() => form.PorcentagemDesconto)"
                                         @bind-Value="form.PorcentagemDesconto" />

                        <MudNumericField T="decimal?"
                                         Label="Valor mínimo da regra"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="0"
                                         Culture="ptBr"
                                         Format="N2"
                                         Adornment="Adornment.Start"
                                         AdornmentText="R$"
                                         FullWidth="true"
                                         For="@(() => form.ValorMinimoRegra)"
                                         @bind-Value="form.ValorMinimoRegra" />
                    </div>

                    <div class="form-actions">
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@isSubmitting">
                            @SubmitButtonText
                        </MudButton>

                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   Disabled="@isSubmitting"
                                   OnClick="@Cancel">
                            Cancelar
                        </MudButton>
                    </div>
                </EditForm>
            }
        </MudPaper>
    </div>
</section>

@code {
    private static readonly CultureInfo ptBr = CultureInfo.GetCultureInfo("pt-BR");
    private CupomFormModel form = new();

    [Parameter]
    public string? Codigo { get; set; }

    private bool isSubmitting;
    private bool isLoading;
    private string? errorMessage;

    private bool IsEditMode => !string.IsNullOrWhiteSpace(Codigo);
    private string PageTitleText => IsEditMode ? "Editar Cupom" : "Cadastrar Cupom";
    private string HeaderTitle => IsEditMode ? "Editar cupom" : "Cadastrar novo cupom";
    private string HeaderDescription => IsEditMode
        ? "Ajuste código, percentual de desconto e regra mínima em uma experiência direta para o operador."
        : "Crie descontos de forma rápida sem depender de chamadas manuais via Postman.";
    private string SubmitButtonText => isSubmitting
        ? (IsEditMode ? "Salvando..." : "Cadastrando...")
        : (IsEditMode ? "Salvar" : "Cadastrar");

    protected override async Task OnParametersSetAsync()
    {
        await LoadFormAsync();
    }

    private async Task LoadFormAsync()
    {
        isLoading = true;
        errorMessage = null;

        if (!IsEditMode)
        {
            form = new CupomFormModel();
            isLoading = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(Codigo))
        {
            form = new CupomFormModel();
            errorMessage = "Cupom inválido para edição.";
            isLoading = false;
            return;
        }

        var editCodigo = Codigo;

        try
        {
            CupomListItem? cupom = await CupomService.ObterPorCodigoAsync(editCodigo);

            if (cupom is null)
            {
                form = new CupomFormModel();
                errorMessage = "Cupom não encontrado.";
                return;
            }

            form = new CupomFormModel
            {
                Codigo = cupom.Codigo,
                PorcentagemDesconto = cupom.PorcentagemDesconto,
                ValorMinimoRegra = cupom.ValorMinimoRegra
            };
        }
        catch
        {
            form = new CupomFormModel();
            errorMessage = "Não foi possível carregar o cupom para edição.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSubmitAsync()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            if (IsEditMode)
            {
                if (string.IsNullOrWhiteSpace(Codigo))
                {
                    errorMessage = "Cupom inválido para edição.";
                    return;
                }

                var editCodigo = Codigo;

                var request = new AtualizarCupomRequest
                {
                    Codigo = form.Codigo.Trim(),
                    PorcentagemDesconto = form.PorcentagemDesconto!.Value,
                    ValorMinimoRegra = form.ValorMinimoRegra!.Value
                };

                var response = await CupomService.AtualizarAsync(editCodigo, request);

                if (!response.Success)
                {
                    errorMessage = response.ErrorMessage;
                    return;
                }

                Snackbar.Add("Cupom atualizado com sucesso.", Severity.Success);
                Navigation.NavigateTo("/cupons");
                return;
            }

            var createRequest = new CriarCupomRequest
            {
                Codigo = form.Codigo.Trim(),
                PorcentagemDesconto = form.PorcentagemDesconto!.Value,
                ValorMinimoRegra = form.ValorMinimoRegra!.Value
            };

            var result = await CupomService.CriarAsync(createRequest);

            if (!result.Success)
            {
                errorMessage = result.ErrorMessage;
                return;
            }

            Snackbar.Add("Cupom cadastrado com sucesso.", Severity.Success);
            Navigation.NavigateTo("/cupons");            
        }
        catch
        {
            errorMessage = IsEditMode
                ? "Falha ao atualizar o cupom."
                : "Falha ao comunicar com a API de cupons.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/cupons");
    }

    private sealed class CupomFormModel
    {
        [Required(ErrorMessage = "Informe o código do cupom.")]
        public string Codigo { get; set; } = string.Empty;

        [Required(ErrorMessage = "Informe a porcentagem de desconto.")]
        [Range(typeof(decimal), "1", "100", ErrorMessage = "A porcentagem de desconto deve estar entre 1 e 100.")]
        public decimal? PorcentagemDesconto { get; set; }

        [Required(ErrorMessage = "Informe o valor mínimo da regra.")]
        [Range(typeof(decimal), "0", "999999999", ErrorMessage = "O valor mínimo da regra não pode ser negativo.")]
        public decimal? ValorMinimoRegra { get; set; }

        public void Reset()
        {
            Codigo = string.Empty;
            PorcentagemDesconto = null;
            ValorMinimoRegra = null;
        }
    }
}
