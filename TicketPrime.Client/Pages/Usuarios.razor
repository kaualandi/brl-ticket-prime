@page "/usuarios"
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Usuários</PageTitle>

<section class="users-page">
    <div class="users-shell">
        <div class="users-header">
            <div>
                <span class="users-eyebrow">Gestão de contas</span>
                <h1>Usuários cadastrados</h1>
                <p>Consulte os usuários registrados no sistema e acompanhe os cadastros.</p>
            </div>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => Navigation.NavigateTo("/usuarios/novo"))">
                Novo usuário
            </MudButton>
        </div>

        <MudPaper Class="users-card" Elevation="0">
            <MudTextField T="string"
                          Label="Buscar por nome ou email"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true"
                          Class="users-search"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          @bind-Value="_searchTerm" />

            @if (_loading)
            {
                <div class="table-loading">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else
            {
                <MudTable T="UsuarioDto"
                          Items="FilteredUsuarios"
                          Hover="true"
                          Breakpoint="Breakpoint.Sm"
                          Class="users-table"
                          Elevation="0">
                    <HeaderContent>
                        <MudTh>Nome</MudTh>
                        <MudTh>Email</MudTh>
                        <MudTh>CPF</MudTh>
                        <MudTh>Ações</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Nome">@context.Nome</MudTd>
                        <MudTd DataLabel="Email">@context.Email</MudTd>
                        <MudTd DataLabel="CPF">@FormatCpf(context.Cpf)</MudTd>
                        <MudTd DataLabel="Ações">
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       OnClick="@(() => Navigation.NavigateTo($"/usuarios/editar/{context.Cpf}"))">
                            </MudButton>
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Delete"
                                       OnClick="@(() => DeleteUsuario(context.Cpf))">
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body1">Nenhum usuário encontrado.</MudText>
                    </NoRecordsContent>
                </MudTable>
            }
        </MudPaper>
    </div>
</section>

@code {
    private List<UsuarioDto> _usuarios = new();
    private bool _loading = true;
    private string _searchTerm = string.Empty;

    private IEnumerable<UsuarioDto> FilteredUsuarios =>
        _usuarios.Where(u => string.IsNullOrWhiteSpace(_searchTerm)
            || u.Nome.Contains(_searchTerm.Trim(), StringComparison.OrdinalIgnoreCase)
            || u.Email.Contains(_searchTerm.Trim(), StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<List<UsuarioDto>>("api/usuarios");
            _usuarios = result ?? new();
        }
        catch
        {
            _usuarios = new();
        }
        finally
        {
            _loading = false;
        }
    }

    private class UsuarioDto
    {
        public string Cpf { get; set; } = string.Empty;
        public string Nome { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
    }

    private static string FormatCpf(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var digits = new string(value.Where(char.IsDigit).Take(11).ToArray());

        return digits.Length switch
        {
            <= 3 => digits,
            <= 6 => $"{digits[..3]}.{digits[3..]}",
            <= 9 => $"{digits[..3]}.{digits[3..6]}.{digits[6..]}",
            _ => $"{digits[..3]}.{digits[3..6]}.{digits[6..9]}-{digits[9..]}"
        };
    }

    private async Task DeleteUsuario(string cpf)
    {
        var options = new MessageBoxOptions
        {
            Title = "Confirmar exclusão",
            Message = "Tem certeza que deseja excluir este usuário?",
            YesText = "Excluir",
            CancelText = "Cancelar"
        };

        var confirm = await DialogService.ShowMessageBoxAsync(options);

        if (confirm != true) return;

        try
        {
            var response = await Http.DeleteAsync($"api/usuarios/{cpf}");
            if (response.IsSuccessStatusCode)
            {
                _usuarios.RemoveAll(u => u.Cpf == cpf);
                Snackbar.Add("Usuário excluído com sucesso!", Severity.Success);
            }
            else
            {
                Snackbar.Add("Erro ao excluir usuário.", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Erro de conexão com o servidor.", Severity.Error);
        }
    }
}
