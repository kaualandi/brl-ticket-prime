@page "/cupons"
@using TicketPrime.Client.Services.Cupons
@inject ICupomService CupomService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Cupons</PageTitle>

<section class="coupons-page">
    <div class="coupons-shell">
        <div class="coupons-header">
            <div>
                <span class="coupons-eyebrow">Operação de cupons</span>
                <h1>Cupons cadastrados</h1>
                <p>Consulte os cupons ativos, filtre por código e acesse a edição quando precisar ajustar regras.</p>
            </div>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@GoToCreate">
                Novo cupom
            </MudButton>
        </div>

        <MudPaper Class="coupons-card" Elevation="0">
            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled" Class="mb-4">
                    @errorMessage
                </MudAlert>
            }

            <MudTextField T="string"
                          Label="Buscar por código"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          FullWidth="true"
                          Class="coupons-search"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          @bind-Value="searchTerm" />

            @if (isLoading)
            {
                <div class="table-loading">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else
            {
                <MudTable T="CupomListItem"
                          Items="FilteredCupons"
                          Hover="true"
                          Breakpoint="Breakpoint.Sm"
                          Class="coupons-table"
                          Elevation="0">
                    <HeaderContent>
                        <MudTh>Código</MudTh>
                        <MudTh>Desconto</MudTh>
                        <MudTh>Valor Mínimo</MudTh>
                        <MudTh>Ações</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Código">@context.Codigo</MudTd>
                        <MudTd DataLabel="Desconto">@context.PorcentagemDesconto.ToString("N0")%</MudTd>
                        <MudTd DataLabel="Valor mínimo">@context.ValorMinimoRegra</MudTd>
                        <MudTd DataLabel="Ações">
                            <MudIconButton Class="action-icon-button"
                                           Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           aria-label="Editar cupom"
                                           OnClick="@(() => GoToEdit(context.Codigo))" />
                            <MudIconButton Class="action-icon-button"
                                           Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           aria-label="Excluir cupom"
                                           OnClick="@(() => DeleteCupom(context.Codigo))" />
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body1">Nenhum cupom encontrado para esse filtro.</MudText>
                    </NoRecordsContent>
                </MudTable>
            }
        </MudPaper>
    </div>
</section>

@code {
    private readonly List<CupomListItem> cupons = [];
    private bool isLoading = true;
    private string? errorMessage;
    private string searchTerm = string.Empty;

    private IEnumerable<CupomListItem> FilteredCupons =>
        cupons.Where(c => string.IsNullOrWhiteSpace(searchTerm)
            || c.Codigo.Contains(searchTerm.Trim(), StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadCuponsAsync();
    }

    private async Task LoadCuponsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await CupomService.ListarAsync();
            cupons.Clear();
            cupons.AddRange(response);
        }
        catch
        {
            errorMessage = "Não foi possível carregar os cupons agora.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToCreate()
    {
        Navigation.NavigateTo("/cupons/novo");
    }

    private void GoToEdit(string codigo)
    {
        Navigation.NavigateTo($"/cupons/editar/{codigo}");
    }

    private async Task DeleteCupom(string codigo)
    {
        var options = new MessageBoxOptions
        {
            Title = "Confirmar exclusão",
            Message = "Tem certeza que deseja excluir este cupom?",
            YesText = "Excluir",
            CancelText = "Cancelar"
        };

        var confirm = await DialogService.ShowMessageBoxAsync(options);
        if (confirm != true) return;

        var result = await CupomService.DeletarAsync(codigo);
        if (result.Success)
        {
            cupons.RemoveAll(c => string.Equals(c.Codigo, codigo, StringComparison.OrdinalIgnoreCase));
            Snackbar.Add("Cupom excluído com sucesso!", Severity.Success);
        }
        else
        {
            Snackbar.Add(result.ErrorMessage ?? "Erro ao excluir cupom.", Severity.Error);
        }
    }
}
