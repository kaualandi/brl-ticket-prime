@page "/cupons/editar/{Codigo}"
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using TicketPrime.Client.Services.Cupons
@inject ICupomService CupomService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Editar Cupom</PageTitle>

<section class="edit-coupon-page">
    <div class="edit-coupon-shell">
        <div class="edit-coupon-header">
            <span class="edit-coupon-eyebrow">Operacao de cupons</span>
            <h1>Editar cupom</h1>
            <p>Ajuste codigo, percentual de desconto e regra minima em uma experiencia direta para o operador.</p>
        </div>

        <MudPaper Class="edit-coupon-card" Elevation="0">
            @if (isLoading)
            {
                <div class="form-loading">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled" Class="mb-4">
                        @errorMessage
                    </MudAlert>
                }

                <EditForm Model="@form" OnValidSubmit="@HandleSubmitAsync">
                    <DataAnnotationsValidator />

                    <div class="form-grid">
                        <MudTextField T="string"
                                      Label="Codigo"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      For="@(() => form.Codigo)"
                                      @bind-Value="form.Codigo" />

                        <MudNumericField T="decimal?"
                                         Label="Porcentagem de desconto"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="1"
                                         Max="100"
                                         Class="percent-field"
                                         Immediate="true"
                                         Adornment="Adornment.End"
                                         AdornmentText="%"
                                         FullWidth="true"
                                         For="@(() => form.PorcentagemDesconto)"
                                         Value="form.PorcentagemDesconto"
                                         ValueChanged="OnPorcentagemChanged" />

                        <MudNumericField T="decimal?"
                                         Label="Valor minimo da regra"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Min="0"
                                         Culture="ptBr"
                                         Format="N2"
                                         Adornment="Adornment.Start"
                                         AdornmentText="R$"
                                         FullWidth="true"
                                         For="@(() => form.ValorMinimoRegra)"
                                         @bind-Value="form.ValorMinimoRegra" />
                    </div>

                    <div class="form-actions">
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@isSubmitting">
                            @(isSubmitting ? "Salvando..." : "Salvar alteracoes")
                        </MudButton>

                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   Disabled="@isSubmitting"
                                   OnClick="@Cancel">
                            Cancelar
                        </MudButton>
                    </div>
                </EditForm>
            }
        </MudPaper>
    </div>
</section>

@code {
    private static readonly CultureInfo ptBr = CultureInfo.GetCultureInfo("pt-BR");

    [Parameter]
    public string Codigo { get; set; } = string.Empty;

    private readonly EditarCupomFormModel form = new();
    private bool isLoading = true;
    private bool isSubmitting;
    private string? errorMessage;
    private string codigoOriginal = string.Empty;

    private void OnPorcentagemChanged(decimal? value)
    {
        if (value is null)
        {
            form.PorcentagemDesconto = null;
            return;
        }

        form.PorcentagemDesconto = decimal.Clamp(value.Value, 1m, 100m);
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            codigoOriginal = Uri.UnescapeDataString(Codigo ?? string.Empty).Trim();
            var cupom = await CupomService.ObterPorCodigoAsync(codigoOriginal);

            if (cupom is null)
            {
                errorMessage = "Cupom nao encontrado.";
                return;
            }

            form.Codigo = cupom.Codigo;
            form.PorcentagemDesconto = cupom.PorcentagemDesconto;
            form.ValorMinimoRegra = cupom.ValorMinimoRegra;
        }
        catch
        {
            errorMessage = "Nao foi possivel carregar o cupom para edicao.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSubmitAsync()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            var request = new AtualizarCupomRequest
            {
                Codigo = form.Codigo.Trim(),
                PorcentagemDesconto = form.PorcentagemDesconto!.Value,
                ValorMinimoRegra = form.ValorMinimoRegra!.Value
            };

            var response = await CupomService.AtualizarAsync(codigoOriginal, request);

            if (!response.Success)
            {
                errorMessage = response.ErrorMessage;
                return;
            }

            Snackbar.Add("Cupom atualizado com sucesso.", Severity.Success);
            Navigation.NavigateTo("/cupons");
        }
        catch
        {
            errorMessage = "Falha ao atualizar o cupom.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/cupons");
    }

    private sealed class EditarCupomFormModel
    {
        [Required(ErrorMessage = "Informe o codigo do cupom.")]
        public string Codigo { get; set; } = string.Empty;

        [Required(ErrorMessage = "Informe a porcentagem de desconto.")]
        [Range(typeof(decimal), "1", "100", ErrorMessage = "A porcentagem de desconto deve estar entre 1 e 100.")]
        public decimal? PorcentagemDesconto { get; set; }

        [Required(ErrorMessage = "Informe o valor minimo da regra.")]
        [Range(typeof(decimal), "0", "999999999", ErrorMessage = "O valor minimo da regra nao pode ser negativo.")]
        public decimal? ValorMinimoRegra { get; set; }
    }
}
