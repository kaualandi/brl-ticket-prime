@page "/eventos"
@using TicketPrime.Client.Models
@using TicketPrime.Client.Services.Eventos
@inject IEventoService EventoService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Eventos</PageTitle>

<section class="events-page">
    <div class="events-shell">
        <section class="events-hero">
            <div class="hero-copy">
                <span class="eyebrow">Curadoria Premium</span>
                <h1>Eventos com presença, clareza e um visual que passa confiança.</h1>
                <p>
                    Uma vitrine moderna para destacar o que importa: contexto, agenda e experiência.
                    Sem poluição visual, sem cara de trabalho improvisado.
                </p>

                <div class="hero-metrics">
                    <div class="metric-card">
                        <span class="metric-value">@eventos.Count</span>
                        <span class="metric-label">Eventos ativos</span>
                    </div>
                    <div class="metric-card">
                        <span class="metric-value">@LocaisUnicos</span>
                        <span class="metric-label">Locais confirmados</span>
                    </div>
                    <div class="metric-card">
                        <span class="metric-value">@(eventos.Count > 0 ? ProximoEvento.DataEvento.ToString("dd MMM") : "-")</span>
                        <span class="metric-label">Próxima data</span>
                    </div>
                </div>
            </div>

            @if (eventos.Count > 0)
            {
                <EventoCard EventoItem="ProximoEvento"
                            Destacado="true"
                            Hero="true"
                            BadgeText="Próximo destaque" />
            }
        </section>

        <div class="events-actions-bar">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="@(() => Navigation.NavigateTo("/eventos/novo"))">
                Novo evento
            </MudButton>
        </div>

        @if (isLoading)
        {
            <div class="table-loading">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Filled">
                @errorMessage
            </MudAlert>
        }
        else if (eventos.Count == 0)
        {
            <section class="empty-state">
                <h2>Nenhum evento encontrado</h2>
                <p>Quando novos eventos forem publicados, eles aparecerão aqui com a mesma organização visual.</p>
            </section>
        }
        else
        {
            <section class="events-grid" aria-label="Lista de eventos">
                @foreach (var evento in eventosOrdenados)
                {
                    var destaque = evento.Id == ProximoEvento.Id;
                    var eventoCapturado = evento;
                    <div class="event-card-wrapper">
                        <EventoCard EventoItem="evento"
                                    Destacado="destaque"
                                    ShowActions="true"
                                    BadgeText="@(destaque ? "Mais próximo" : "Agenda aberta")">
                            <ActionsContent>
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Edit"
                                           OnClick="@(() => Navigation.NavigateTo($"/eventos/editar/{eventoCapturado.Id}"))">
                                </MudButton>
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.Delete"
                                           OnClick="@(() => DeleteEvento(eventoCapturado.Id))">
                                </MudButton>
                            </ActionsContent>
                        </EventoCard>
                    </div>
                }
            </section>
        }
    </div>
</section>

@code {
    private List<Evento> eventos = new();
    private bool isLoading = true;
    private string? errorMessage;

    private List<Evento> eventosOrdenados => eventos.OrderBy(e => e.DataEvento).ToList();

    private Evento ProximoEvento => eventosOrdenados.FirstOrDefault() ?? new Evento
    {
        Nome = "Sem eventos",
        Descricao = "Nenhum evento cadastrado no momento.",
        CapacidadeTotal = 0,
        DataEvento = DateTime.Today,
        PrecoPadrao = 0m,
        LocalEvento = "A definir"
    };

    private int LocaisUnicos => eventos
        .Select(e => e.LocalEvento)
        .Where(local => !string.IsNullOrWhiteSpace(local))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();

    protected override async Task OnInitializedAsync()
    {
        await LoadEventosAsync();
    }

    private async Task LoadEventosAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var data = await EventoService.ListarAsync();
            eventos = data.Select(e => new Evento
            {
                Id = e.Id,
                Nome = e.Nome,
                Descricao = e.Descricao,
                CapacidadeTotal = e.CapacidadeTotal,
                DataEvento = e.DataEvento,
                PrecoPadrao = e.PrecoPadrao,
                LocalEvento = e.LocalEvento,
                ImageUrl = e.ImageUrl
            }).ToList();
        }
        catch
        {
            errorMessage = "Não foi possível carregar os eventos agora.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteEvento(int id)
    {
        var options = new MessageBoxOptions
        {
            Title = "Confirmar exclusão",
            Message = "Tem certeza que deseja excluir este evento?",
            YesText = "Excluir",
            CancelText = "Cancelar"
        };

        var confirm = await DialogService.ShowMessageBoxAsync(options);
        if (confirm != true) return;

        var result = await EventoService.DeletarAsync(id);
        if (result.Success)
        {
            eventos.RemoveAll(e => e.Id == id);
            Snackbar.Add("Evento excluído com sucesso!", Severity.Success);
        }
        else
        {
            Snackbar.Add(result.ErrorMessage ?? "Erro ao excluir evento.", Severity.Error);
        }
    }
}
